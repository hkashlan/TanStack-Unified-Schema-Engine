{
  "name": "@tanstack-use/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/schema.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:"
  },
  "scripts": {
    "test:types": "tsd"
  },
  "tsd": {
    "directory": "src",
    "compilerOptions": {
      "moduleResolution": "bundler",
      "module": "ESNext",
      "target": "ES2022",
      "strict": true
    }
  }
}
